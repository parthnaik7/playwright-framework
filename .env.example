# ============================================================
# Environment Configuration Template
# Copy this file to .env.dev / .env.qa / .env.prod and fill in values.
# NEVER commit real credentials to source control.
# ============================================================

# Application environment identifier
APP_ENV=dev

# Base URL for the application under test
BASE_URL=https://www.saucedemo.com

# API base URL (if the AUT has a REST API)
API_BASE_URL=https://api.example.com

# Standard test credentials
STANDARD_USER=standard_user
STANDARD_PASSWORD=secret_sauce

# Locked-out user credentials (for negative tests)
LOCKED_USER=locked_out_user
LOCKED_PASSWORD=secret_sauce

# Problem user credentials
PROBLEM_USER=problem_user
PROBLEM_PASSWORD=secret_sauce

# Performance glitch user
PERF_GLITCH_USER=performance_glitch_user
PERF_GLITCH_PASSWORD=secret_sauce

# Test timeouts (ms)
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=60000
EXPECT_TIMEOUT=10000

# Browser configuration
HEADLESS=true
BROWSER=chromium
SLOW_MO=0

# Retry configuration
RETRIES=2
WORKERS=4

# Logging
LOG_LEVEL=info
ENABLE_VIDEO=false
ENABLE_SCREENSHOTS=true
ENABLE_TRACES=true
